{
  "name": "baileys-sidecar",
  "version": "1.0.0",
  "type": "module",
  "description": "WhatsApp Baileys HTTP sidecar for Nexus — uses upstream @whiskeysockets/baileys (no fork)",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "test": "tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "express": "^5.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.9.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
