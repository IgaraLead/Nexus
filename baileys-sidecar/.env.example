# ============================================================
#  Baileys Sidecar – Variáveis de Ambiente (produção)
#  Copie para .env e preencha os valores marcados como TROQUE.
#
#  Arquitetura de produção:
#    VPS 1 → roda junto com Nexus (conecta via rede igaralead_public)
#
#  🔧 DEV: linhas marcadas com "# [DEV]" mostram o valor para
#     desenvolvimento local.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3500
NODE_ENV=production
# [DEV] NODE_ENV=development
# LOG_LEVEL=info

# ── Auth ─────────────────────────────────────────────────────
BAILEYS_SIDECAR_API_KEY=TROQUE-api-key

# ── Webhook (Nexus) ─────────────────────────────────────────
# Produção: serviço Nexus via rede Docker interna
NEXUS_WEBHOOK_URL=http://nexus-rails:3000
# [DEV] NEXUS_WEBHOOK_URL=http://localhost:3000

# ── Storage ──────────────────────────────────────────────────
# SESSIONS_DIR=./sessions
# MEDIA_DIR=./media
